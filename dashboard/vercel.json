{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://beezy-agents-ingestion.replit.app"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://beezy-agents-ingestion.replit.app/api/:path*"
    }
  ]
}
